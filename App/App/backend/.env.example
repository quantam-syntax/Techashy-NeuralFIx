# ─── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── PostgreSQL ───────────────────────────────────────────
# Make sure PostgreSQL is running and this DB exists
DATABASE_URL=postgresql://netfix:netfix123@localhost:5432/netfixai

# ─── Server ───────────────────────────────────────────────
# Set this to your server machine's local IP (run: ipconfig or ifconfig)
HOST=0.0.0.0
PORT=8000

# ─── RAG ──────────────────────────────────────────────────
# Path to folder containing your networking PDF/TXT manuals
DOCS_PATH=./docs
# Path where FAISS vector index will be saved/loaded
VECTOR_STORE_PATH=./vector_store

# ─── App ──────────────────────────────────────────────────
APP_NAME=NetFixAI
DEBUG=true
